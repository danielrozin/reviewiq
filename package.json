{
  "name": "smartreview",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "(prisma generate || true) && next build",
    "start": "next start",
    "lint": "next lint",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:migrate": "npx prisma migrate dev",

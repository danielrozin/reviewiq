# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartreview?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# OAuth Providers (optional — enables social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# DataForSEO API (keyword discovery + SEO insights)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Tavily API (web search enrichment, Quora/Reddit discovery)
TAVILY_API_KEY=

# Apify API (competitor scraping, YouTube/social monitoring)
APIFY_API_TOKEN=

# Cron secret (protects /api/cron/* routes — Vercel sets this automatically)
CRON_SECRET=

# Redis (Upstash — optional, enables API response caching)
UPSTASH_REDIS_REST_URL=          # e.g. https://us1-xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=        # Upstash REST token

# Stripe Payment Processing
STRIPE_SECRET_KEY=               # Stripe secret key (sk_live_... or sk_test_...)
STRIPE_PRO_PRICE_ID=             # Stripe Price ID for Pro plan ($9.99/month)
STRIPE_WEBHOOK_SECRET=           # Stripe webhook signing secret (whsec_...)

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=SmartReview

# Analytics & Conversion Tracking
NEXT_PUBLIC_GTM_ID=              # Google Tag Manager container (e.g. GTM-XXXXXXX) — use this OR GA_ID, not both
NEXT_PUBLIC_GA_ID=               # GA4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GOOGLE_ADS_ID=       # Google Ads account (e.g. AW-XXXXXXXXX)
NEXT_PUBLIC_META_PIXEL_ID=       # Meta/Facebook Pixel ID
NEXT_PUBLIC_CLARITY_ID=w3w5leh6ae # Microsoft Clarity project ID

# Admin Dashboard
ADMIN_PASSWORD=                  # Password for /admin dashboard access

# Sentry Error Tracking
SENTRY_DSN=                      # Sentry DSN (server-side)
NEXT_PUBLIC_SENTRY_DSN=          # Sentry DSN (client-side)
SENTRY_ORG=                      # Sentry organization slug
SENTRY_PROJECT=                  # Sentry project slug
SENTRY_AUTH_TOKEN=               # Sentry auth token (for source map uploads)

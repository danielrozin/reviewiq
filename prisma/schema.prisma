generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// NextAuth.js Models
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// Core Models
// ==========================================

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?   @unique
  emailVerified       DateTime?
  image               String?
  username            String?   @unique
  bio                 String?   @db.Text
  trustLevel          String    @default("newcomer")
  reputationScore     Int       @default(0)
  badges              String[]  @default([])
  expertiseCategories String[]  @default([])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  reviews             Review[]
  threads             DiscussionThread[]
  comments            Comment[]
  votes               Vote[]
  reports             ModerationReport[] @relation("Reporter")
  savedComparisons    SavedComparison[]
  watchlistItems      WatchlistItem[]
  subscription        Subscription?
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  icon        String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
  threads  DiscussionThread[]
}

model Product {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  brand                String
  categoryId           String
  description          String   @db.Text
  image                String
  priceMin             Int
  priceMax             Int
  priceCurrency        String   @default("USD")
  smartScore           Int      @default(0)
  verifiedPurchaseRate Int      @default(0)
  reviewCount          Int      @default(0)
  ratingDist5          Int      @default(0)
  ratingDist4          Int      @default(0)
  ratingDist3          Int      @default(0)
  ratingDist2          Int      @default(0)
  ratingDist1          Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  category         Category          @relation(fields: [categoryId], references: [id])
  reviews          Review[]
  threads          DiscussionThread[]
  specs            ProductSpec[]
  aiSummary        AISummary?
  issues           RecurringIssue[]
  faqs             FAQ[]
  videos           YouTubeVideo[]
  savedComparisons SavedComparison[]
  watchlistItems   WatchlistItem[]

  @@index([categoryId])
  @@index([brand])
  @@index([smartScore])
}

model AISummary {
  id             String   @id @default(cuid())
  productId      String   @unique
  whatPeopleLove String[]
  whatPeopleHate String[]
  bestFor        String[]
  notFor         String[]
  topComplaints  String[]
  keyFacts       String[]

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSpec {
  id        String  @id @default(cuid())
  productId String
  label     String
  value     String
  group     String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model RecurringIssue {
  id           String @id @default(cuid())
  productId    String
  title        String
  mentionCount Int    @default(0)
  severity     String
  description  String @db.Text

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model FAQ {
  id        String @id @default(cuid())
  productId String
  question  String @db.Text
  answer    String @db.Text

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model YouTubeVideo {
  id        String @id @default(cuid())
  productId String
  videoId   String
  title     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ==========================================
// Reviews
// ==========================================

model Review {
  id               String   @id @default(cuid())
  productId        String
  userId           String
  headline         String
  rating           Int
  verifiedPurchase Boolean  @default(false)
  verificationTier String   @default("unverified")
  timeOwned        String?
  experienceLevel  String   @default("intermediate")
  pros             String[]
  cons             String[]
  reliabilityRating Int?
  easeOfUseRating   Int?
  valueRating       Int?
  body             String   @db.Text
  aiTopics         String[] @default([])
  helpfulCount     Int      @default(0)
  status           String   @default("published")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
  votes   Vote[]

  @@index([productId])
  @@index([userId])
  @@index([rating])
}

// ==========================================
// Discussions
// ==========================================

model DiscussionThread {
  id           String   @id @default(cuid())
  title        String
  body         String   @db.Text
  threadType   String
  authorId     String
  productId    String?
  categoryId   String?
  upvotes      Int      @default(0)
  downvotes    Int      @default(0)
  commentCount Int      @default(0)
  viewCount    Int      @default(0)
  isPinned     Boolean  @default(false)
  isResolved   Boolean  @default(false)
  tags         String[] @default([])
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  author   User      @relation(fields: [authorId], references: [id])
  product  Product?  @relation(fields: [productId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
  comments Comment[]
  votes    Vote[]

  @@index([authorId])
  @@index([productId])
  @@index([categoryId])
  @@index([threadType])
}

model Comment {
  id              String   @id @default(cuid())
  threadId        String
  parentId        String?
  authorId        String
  body            String   @db.Text
  upvotes         Int      @default(0)
  downvotes       Int      @default(0)
  isTopAnswer     Boolean  @default(false)
  isOwnerVerified Boolean  @default(false)
  helpfulCount    Int      @default(0)
  status          String   @default("published")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  thread  DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  parent  Comment?         @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[]        @relation("CommentReplies")
  author  User             @relation(fields: [authorId], references: [id])
  votes   Vote[]

  @@index([threadId])
  @@index([parentId])
  @@index([authorId])
}

// ==========================================
// Votes
// ==========================================

model Vote {
  id        String   @id @default(cuid())
  userId    String
  voteType  String
  reviewId  String?
  threadId  String?
  commentId String?
  createdAt DateTime @default(now())

  user    User              @relation(fields: [userId], references: [id])
  review  Review?           @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  thread  DiscussionThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  comment Comment?          @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId, voteType])
  @@unique([userId, threadId, voteType])
  @@unique([userId, commentId, voteType])
  @@index([userId])
}

// ==========================================
// Dashboard: Saved Comparisons & Watchlist
// ==========================================

model SavedComparison {
  id        String   @id @default(cuid())
  userId    String
  productId String
  note      String?  @db.Text
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model WatchlistItem {
  id              String   @id @default(cuid())
  userId          String
  productId       String
  lastKnownScore  Int      @default(0)
  createdAt       DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ==========================================
// Moderation
// ==========================================

model ModerationReport {
  id          String   @id @default(cuid())
  contentType String
  contentId   String
  reporterId  String
  reason      String
  details     String?  @db.Text
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporter User @relation("Reporter", fields: [reporterId], references: [id])

  @@index([contentType, contentId])
  @@index([status])
  @@index([reporterId])
}

// ==========================================
// Subscriptions (Stripe)
// ==========================================

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  status               String    @default("inactive") // active, canceled, past_due, incomplete, trialing
  plan                 String    @default("free") // free, pro
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([status])
}

// ==========================================
// Email Subscriptions
// ==========================================

model EmailSubscription {
  id             String    @id @default(cuid())
  email          String
  productId      String
  productSlug    String
  productName    String
  unsubscribeToken String  @unique @default(cuid())
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())

  @@unique([email, productId])
  @@index([productId])
  @@index([email])
  @@index([unsubscribeToken])
}

// ==========================================
// GDPR Consent Management
// ==========================================

model ConsentRecord {
  id               String   @id @default(cuid())
  visitorId        String
  consentCategories Json
  ipHash           String?
  policyVersion    String
  userAgent        String?  @db.Text
  geoCountry       String?
  grantedAt        DateTime @default(now())
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([visitorId])
  @@index([grantedAt])
  @@index([geoCountry])
}

// ==========================================
// User Research Surveys
// ==========================================

model SmartreviewSurvey {
  id                     String   @id @default(cuid())
  userType               String?
  actionType             String?
  category               String?
  reviewCompletionTimeSec Int?
  formFieldsFilled       Int?
  surveyCompleted        Boolean  @default(false)
  q1Intent               String?
  q2Found                Boolean?
  q2Missing              String?  @db.Text
  q3Rating               Int?
  q4Improvement          String?  @db.Text
  q5Discovery            String?
  deviceType             String?
  referralSource         String?
  optInEmail             String?
  createdAt              DateTime @default(now())

  @@index([createdAt])
  @@index([category])
}
